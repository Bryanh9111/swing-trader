# Automated Swing Trading System - Secrets Template
# Copy this file to secrets.env and fill in your actual credentials
# ⚠️  NEVER commit secrets.env to git! It is in .gitignore

# ==============================================================================
# IBKR (Interactive Brokers) Credentials
# ==============================================================================
# Paper Trading Account
IBKR_PAPER_USERNAME=your_paper_username
IBKR_PAPER_PASSWORD=your_paper_password
IBKR_PAPER_TRADING_MODE=paper
IBKR_PAPER_HOST=127.0.0.1
IBKR_PAPER_PORT=7497

# Live Trading Account (requires additional security)
IBKR_LIVE_USERNAME=your_live_username
IBKR_LIVE_PASSWORD=your_live_password
IBKR_LIVE_TRADING_MODE=live
IBKR_LIVE_HOST=127.0.0.1
IBKR_LIVE_PORT=7496

# ==============================================================================
# Data Source API Keys
# ==============================================================================
# Polygon.io (Primary EOD/Intraday data)
POLYGON_API_KEY=your_polygon_api_key

# EODHD (Secondary EOD data)
EODHD_API_KEY=your_eodhd_api_key

# Financial Modeling Prep (Fundamentals)
FMP_API_KEY=your_fmp_api_key

# Finnhub (News/Sentiment)
FINNHUB_API_KEY=your_finnhub_api_key

# IEX Cloud (Tertiary fallback)
IEX_CLOUD_TOKEN=your_iex_cloud_token

# Tiingo (Tertiary fallback)
TIINGO_API_KEY=your_tiingo_api_key

# Alpha Vantage (Tertiary fallback)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# ==============================================================================
# Monitoring & Alerts
# ==============================================================================
# Email alerts (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password
ALERT_EMAIL_TO=your_alert_email@gmail.com

# Telegram alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Slack alerts (optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url

# ==============================================================================
# Database (if using external DB)
# ==============================================================================
# PostgreSQL (optional, for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/trading_system

# ==============================================================================
# Secrets Manager (optional, for production)
# ==============================================================================
# AWS Secrets Manager
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=trading-system-secrets

# HashiCorp Vault
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=your_vault_token

# ==============================================================================
# Security
# ==============================================================================
# Encryption key for sensitive data at rest
ENCRYPTION_KEY=generate_a_random_32_byte_key_here

# API rate limiting (to avoid abuse)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_TIME_WINDOW_SECONDS=60

# ==============================================================================
# S3 Historical Data Credentials
# ==============================================================================
S3_ENDPOINT_URL=https://your-s3-endpoint.example.com
S3_ACCESS_KEY_ID=your_s3_access_key_here
S3_SECRET_ACCESS_KEY=your_s3_secret_key_here
S3_BUCKET_NAME=your-bucket-name
